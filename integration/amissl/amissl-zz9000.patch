@@ -361,6 +361,14 @@ LIBPROTO(InitAmiSSLA, LONG, REG(a6, __BASE_OR_IFACE), REG(a0, struct TagItem *ta
 
     initialize_socket_errno(state);
 
+    /* ZZ9000: register the hardware crypto-offload provider for this
+     * applications default OpenSSL context (best-effort; on failure
+     * the application simply uses AmiSSL software crypto). */
+    {
+      extern int zz9k_provider_register_builtin(void *libctx);
+      zz9k_provider_register_builtin((void *)0);
+    }
+
     err = 0;
